{
  "name": "@openmail/shared",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/db/schema/index.ts",
    "./db": "./src/db/client.ts",
    "./types": "./src/types/index.ts",
    "./ids": "./src/ids.ts",
    "./segment-sql": "./src/segment-sql.ts",
    "./lifecycle-events": "./src/lifecycle-events.ts",
    "./lifecycle-constants": "./src/lifecycle-constants.ts",
    "./lifecycle-events-payload-schemas": "./src/lifecycle-events-payload-schemas.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "check:event-types": "bun run scripts/generate-event-type-check.ts --verify",
    "print:event-types": "bun run scripts/generate-event-type-check.ts --print"
  },
  "dependencies": {
    "drizzle-orm": "^0.41.0",
    "postgres": "^3.4.5",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3"
  }
}

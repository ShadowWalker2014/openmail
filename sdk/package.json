{
  "name": "@openmail/sdk",
  "version": "1.0.0",
  "description": "OpenMail SDK — track events, identify users, and run email campaigns. Compatible with Segment and PostHog interfaces.",
  "license": "ELv2",
  "type": "module",
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18.0.0" },
  "repository": {
    "type": "git",
    "url": "https://github.com/ShadowWalker2014/openmail.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/ShadowWalker2014/openmail/tree/main/sdk",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs",
      "types": "./dist/browser.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "types": "./dist/react.d.ts"
    },
    "./nextjs": {
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.cjs",
      "types": "./dist/nextjs.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^28.1.0",
    "msw": "^2.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "openmail",
    "analytics",
    "tracking",
    "email",
    "segment",
    "posthog",
    "identify",
    "events",
    "customer-io",
    "mcp",
    "typescript"
  ]
}

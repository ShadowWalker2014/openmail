{
  "name": "@openmail/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "test": "bun test src/routes/domains.test.ts",
    "test:verbose": "bun test --verbose src/routes/domains.test.ts",
    "test:integration": "bun test src/integration/domains.integration.test.ts",
    "test:all": "bun test src/routes/domains.test.ts && bun test src/integration/domains.integration.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.3",
    "@openmail/shared": "workspace:*",
    "better-auth": "1.5.4",
    "bullmq": "^5.30.1",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.4",
    "nanoid": "^5.1.5",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "resend": "^4.2.0",
    "svix": "^1.87.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.3",
    "@types/bun": "latest"
  }
}

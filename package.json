{
  "name": "openmail",
  "private": true,
  "workspaces": [
    "packages/*",
    "api",
    "mcp",
    "worker",
    "tracker",
    "web"
  ],
  "scripts": {
    "dev:api": "bun --cwd api dev",
    "dev:mcp": "bun --cwd mcp dev",
    "dev:worker": "bun --cwd worker dev",
    "dev:tracker": "bun --cwd tracker dev",
    "dev:web": "bun --cwd web dev",
    "db:generate": "bun --cwd packages/shared db:generate",
    "db:migrate": "bun --cwd packages/shared db:migrate",
    "db:studio": "bun --cwd packages/shared db:studio"
  }
}

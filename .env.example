# =============================================
# OpenMail — Environment Variables
# =============================================
# Copy to .env and fill in your values.
# Service-specific vars go in api/.env.local, worker/.env.local, etc.

# Required for email sending
RESEND_API_KEY=re_your_resend_api_key

# Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret

# Public URLs (set after deployment)
BETTER_AUTH_URL=http://localhost:3001
WEB_URL=http://localhost:5173
TRACKER_URL=http://localhost:3003

# Email defaults (workspace can override per-workspace)
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_FROM_NAME=Your App
